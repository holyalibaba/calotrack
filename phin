const toDateKey = ts => { const d=new Date(ts); return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; };
const formatDateLabel = key => {
const [y,m,d]=key.split(”-”).map(Number), date=new Date(y,m-1,d), today=new Date(); today.setHours(0,0,0,0);
const yesterday=new Date(today); yesterday.setDate(today.getDate()-1);
if(date.getTime()===today.getTime()) return “Hôm nay”;
if(date.getTime()===yesterday.getTime()) return “Hôm qua”;
return date.toLocaleDateString(“vi-VN”,{weekday:“long”,day:“numeric”,month:“numeric”});
};
const sum = list => list.reduce((a,e)=>({calories:a.calories+(e.calories||0),protein:a.protein+(e.protein||0),fat:a.fat+(e.fat||0),carbs:a.carbs+(e.carbs||0),fiber:a.fiber+(e.fiber||0),sodium:a.sodium+(e.sodium||0)}),{calories:0,protein:0,fat:0,carbs:0,fiber:0,sodium:0});
const unitMult = (food, unit) => {
const u=unit.toLowerCase(), nm=u.match(/^([\d.]+)/), n=nm?parseFloat(nm[1]):1;
if(food.per===100){ const g=u.match(/(?([\d.]+)\s*g)?/), ml=u.match(/(?([\d.]+)\s*ml)?/); if(g) return parseFloat(g[1])/100; if(ml) return parseFloat(ml[1])/100; if(u.startsWith(“100”)) return 1; return n; }
return n;
};

function App() {
