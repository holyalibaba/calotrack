        <div style={{display:"flex",gap:8,marginBottom:8,alignItems:"flex-end"}}>
          <div style={{display:"flex",flexDirection:"column",gap:4}}>
            <span style={{fontSize:10,color:"#64748b"}}>① Số lượng</span>
            <input value={qty} onChange={e=>setQty(e.target.value)} placeholder="VD: 2" style={{width:72,background:"#0f172a",border:"2px solid #38bdf8",borderRadius:10,padding:"8px 10px",color:"#e2e8f0",fontSize:14,outline:"none"}}/>
          </div>
          <div style={{display:"flex",flexDirection:"column",gap:4,flex:1}}>
            <span style={{fontSize:10,color:"#64748b"}}>② Tên món</span>
            <input value={input} onChange={e=>setInput(e.target.value)} placeholder="Tên món ăn..." onKeyDown={e=>e.key==="Enter"&&handleAdd()} style={{...s.input}}/>
          </div>
        </div>
        <button onClick={handleAdd} disabled={!input.trim()} style={s.btn("#3b82f6","#fff",!input.trim())}>➕ Thêm món</button>
      </div>

      <div style={s.card}>
        <div style={{fontSize:12,color:"#94a3b8",fontWeight:600,marginBottom:10}}>⚡ Chọn nhanh</div>
        {FOOD_GROUPS.map(group=>(
          <div key={group.label} style={{marginBottom:8}}>
            <button onClick={()=>toggleGroup(group.label)} style={{width:"100%",background:"#0f172a",border:"none",borderRadius:10,padding:"7px 12px",display:"flex",justifyContent:"space-between",alignItems:"center",cursor:"pointer",marginBottom:expandedGroups[group.label]?8:0}}>
              <span style={{fontSize:13,color:"#94a3b8",fontWeight:600}}>{group.label}</span>
              <span style={{color:"#475569",fontSize:11}}>{expandedGroups[group.label]?"▲":"▼"}</span>
            </button>
            {expandedGroups[group.label] && (
              <div style={{display:"flex",flexWrap:"wrap",gap:7,paddingLeft:4}}>
                {group.keys.map(k=><button key={k} onClick={()=>handleQuickSelect(k)} style={s.foodBtn(selectedFood===k)}>{k.charAt(0).toUpperCase()+k.slice(1)}</button>)}
              </div>
            )}
          </div>
        ))}
        {selectedFood && pFood && (
          <div style={{background:"#0f172a",borderRadius:12,padding:12,marginTop:10}}>
            <div style={{fontSize:13,fontWeight:700,color:"#e2e8f0",marginBottom:8}}>{selectedFood.charAt(0).toUpperCase()+selectedFood.slice(1)}</div>
            <div style={{display:"flex",flexWrap:"wrap",gap:6,marginBottom:10}}>{pFood.units.map(u=><button key={u} onClick={()=>setSelectedUnit(u)} style={s.chip(selectedUnit===u)}>{u}</button>)}</div>
            <div style={{display:"flex",flexWrap:"wrap",gap:6,marginBottom:10}}>
              <span style={s.tag("#1e3a5f","#38bdf8")}><b>{(pFood.calories*pMult).toFixed(0)}</b> kcal</span>
              <span style={s.tag("#1e1b4b","#818cf8")}>P: {(pFood.protein*pMult).toFixed(1)}g</span>
              <span style={s.tag("#431407","#fb923c")}>F: {(pFood.fat*pMult).toFixed(1)}g</span>
              <span style={s.tag("#422006","#facc15")}>C: {(pFood.carbs*pMult).toFixed(1)}g</span>
            </div>
            <button onClick={handleQuickAdd} style={s.btn("#16a34a","#fff",false)}>✅ Thêm vào nhật ký</button>
          </div>
        )}
      </div>
    </>}

    {tab==="log" && <>
      {sortedDays.length===0 && <div style={{textAlign:"center",color:"#475569",fontSize:14,padding:40}}>Chưa có nhật ký nào 🍽️</div>}
      {sortedDays.map(dayKey=>{
        const dayItems=grouped[dayKey], ds=sum(dayItems), exp=expandedDays[dayKey]!==false, dCalPct=pct(ds.calories,DAILY_GOALS.calories);
        return <div key={dayKey} style={{...s.card,padding:0,overflow:"hidden"}}>
          <button onClick={()=>toggleDay(dayKey)} style={{width:"100%",background:"none",border:"none",padding:"12px 14px",cursor:"pointer",textAlign:"left",display:"flex",alignItems:"center",justifyContent:"space-between"}}>
            <div><div style={{fontSize:14,fontWeight:700,color:"#e2e8f0"}}>{formatDateLabel(dayKey)}</div><div style={{fontSize:11,color:"#64748b"}}>{dayKey} · {dayItems.length} món</div></div>
            <div style={{textAlign:"right"}}>
              <div style={{fontSize:16,fontWeight:700,color:dCalPct>=100?"#ef4444":"#38bdf8"}}>{ds.calories.toFixed(0)} kcal</div>
              <div style={{fontSize:11,color:dCalPct>=100?"#fca5a5":"#86efac"}}>{dCalPct>=100?`+${(ds.calories-DAILY_GOALS.calories).toFixed(0)}`:`${(DAILY_GOALS.calories-ds.calories).toFixed(0)} còn lại`}</div>
            </div>
          </button>
          <div style={{height:4,background:"#0f172a",margin:"0 14px"}}><div style={{width:`${dCalPct}%`,height:"100%",background:barColor(dCalPct),borderRadius:99}}/></div>
          {exp && <div style={{padding:"10px 14px 14px"}}>
            <div style={{background:"#0f172a",borderRadius:12,padding:"10px 12px",marginBottom:10}}>
              <div style={{fontSize:11,color:"#64748b",fontWeight:600,marginBottom:6}}>TỔNG DINH DƯỠNG NGÀY</div>
              {[["🔵 Calo",ds.calories,"kcal","#38bdf8"],["🟣 Protein",ds.protein,"g","#818cf8"],["🟠 Chất béo",ds.fat,"g","#fb923c"],["🟡 Carbs",ds.carbs,"g","#facc15"],["🟢 Chất xơ",ds.fiber,"g","#34d399"],["🩷 Natri",ds.sodium,"mg","#f472b6"]].map(([l,v,u,c])=>(
                <div key={l} style={{display:"flex",justifyContent:"space-between",padding:"3px 0",borderBottom:"1px solid #1e293b"}}>
                  <span style={{fontSize:12,color:"#94a3b8"}}>{l}</span><span style={{fontSize:12,fontWeight:700,color:c}}>{Number(v).toFixed(1)} {u}</span>
                </div>
              ))}
            </div>
            {dayItems.map(e=>(
              <div key={e.id} style={{...s.darkCard,display:"flex",gap:8}}>
                <div style={{flex:1}}>
                  <div style={{fontWeight:600,fontSize:13}}>{e.name}</div>
                  <div style={{fontSize:10,color:"#64748b",marginBottom:3}}>{e.amount}</div>
                  <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
                    <span style={s.tag("#1e3a5f","#38bdf8")}><b>{e.calories}</b> kcal</span>
                    <span style={s.tag("#1e1b4b","#818cf8")}>P:{e.protein}g</span>
                    <span style={s.tag("#431407","#fb923c")}>F:{e.fat}g</span>
                    <span style={s.tag("#422006","#facc15")}>C:{e.carbs}g</span>
                  </div>
                </div>
                <button onClick={()=>remove(e.id)} style={{background:"none",border:"none",color:"#475569",cursor:"pointer",fontSize:18,padding:0,alignSelf:"center"}}>×</button>
              </div>
            ))}
          </div>}
        </div>;
      })}
    </>}

    {tab==="data" && <>
      <div style={s.card}>
        <div style={{fontSize:14,fontWeight:700,color:"#e2e8f0",marginBottom:6}}>☁️ Lưu tự động (localStorage)</div>
        <div style={{fontSize:13,color:"#94a3b8",marginBottom:12}}>Dữ liệu lưu tự động vào bộ nhớ trình duyệt. Không mất khi đóng app, chỉ mất nếu xóa cache Safari.</div>
        <div style={{background:"#0f172a",borderRadius:10,padding:"10px 14px",display:"flex",justifyContent:"space-between"}}>
          <span style={{fontSize:13,color:"#94a3b8"}}>Tổng bản ghi</span>
          <span style={{fontSize:15,fontWeight:700,color:"#38bdf8"}}>{entries.length} món · {sortedDays.length} ngày</span>
        </div>
      </div>
      <div style={s.card}>
        <div style={{fontSize:14,fontWeight:700,color:"#e2e8f0",marginBottom:6}}>📤 Sao lưu</div>
        <div style={{fontSize:13,color:"#94a3b8",marginBottom:10}}>Xuất file JSON để sao lưu an toàn. Nên làm 1 lần/tuần.</div>
        <button onClick={exportData} disabled={entries.length===0} style={s.btn("#0369a1","#fff",entries.length===0)}>📥 Tải file JSON ({entries.length} bản ghi)</button>
      </div>
      <div style={s.card}>
        <div style={{fontSize:14,fontWeight:700,color:"#e2e8f0",marginBottom:6}}>📥 Khôi phục</div>
        <div style={{fontSize:13,color:"#94a3b8",marginBottom:10}}>Nhập file JSON để khôi phục dữ liệu.</div>
        <input ref={fileRef} type="file" accept=".json" onChange={importData} style={{display:"none"}}/>
        <button onClick={()=>fileRef.current.click()} style={s.btn("#065f46","#fff",false)}>📂 Chọn file JSON</button>
      </div>
      <div style={s.card}>
        <div style={{fontSize:14,fontWeight:700,color:"#ef4444",marginBottom:6}}>🗑 Xóa tất cả</div>
        <button onClick={()=>{ if(window.confirm("Xóa toàn bộ? Không thể hoàn tác!")) { setEntries([]); localStorage.removeItem(STORAGE_KEY); }}} style={s.btn("#7f1d1d","#fca5a5",false)}>❌ Xóa tất cả dữ liệu</button>
      </div>
    </>}
  </div>
</div>
