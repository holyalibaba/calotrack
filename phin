const [input, setInput] = useState(””); const [qty, setQty] = useState(””);
const [tab, setTab] = useState(“add”);
const [expandedDays, setExpandedDays] = useState({});
const [expandedGroups, setExpandedGroups] = useState({“🍜 Món chính”:true});
const [selectedFood, setSelectedFood] = useState(null); const [selectedUnit, setSelectedUnit] = useState(””);
const fileRef = useRef();

useEffect(() => { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(entries)); } catch {} }, [entries]);

const todayEntries = entries.filter(e=>toDateKey(e.id)===toDateKey(Date.now()));
const totals = sum(todayEntries);
const findInDB = text => { const t=text.toLowerCase(); for(const [k,v] of Object.entries(FOOD_DB)) if(t.includes(k)) return {…v,name:k}; return null; };

const addEntry = (food, mult, unitLabel) => setEntries(prev=>[…prev,{
…food, id:Date.now(), name:food.name.charAt(0).toUpperCase()+food.name.slice(1),
amount:unitLabel||food.amount,
calories:+(food.calories*mult).toFixed(1), protein:+(food.protein*mult).toFixed(1),
fat:+(food.fat*mult).toFixed(1), carbs:+(food.carbs*mult).toFixed(1),
fiber:+(food.fiber*mult).toFixed(1), sodium:+(food.sodium*mult).toFixed(0),
}]);

const handleAdd = () => {
if(!input.trim()) return;
const found=findInDB(input), n=parseFloat(qty)||1;
if(found){ addEntry({…found,name:found.name},n,qty?`${qty} ${found.name}`:null); setInput(””); setQty(””); }
else alert(“Không tìm thấy món này trong database. Hãy thử tên khác.”);
};

const handleQuickSelect = key => { if(selectedFood===key){setSelectedFood(null);setSelectedUnit(””);return;} setSelectedFood(key); setSelectedUnit(FOOD_DB[key].defaultUnit); };
const handleQuickAdd = () => { if(!selectedFood||!selectedUnit) return; const food=FOOD_DB[selectedFood]; addEntry({…food,name:selectedFood},unitMult(food,selectedUnit),selectedUnit); setSelectedFood(null); setSelectedUnit(””); };

const remove = id => setEntries(prev=>prev.filter(e=>e.id!==id));
const toggleDay = key => setExpandedDays(prev=>({…prev,[key]:!(prev[key]!==false)}));
const toggleGroup = label => setExpandedGroups(prev=>({…prev,[label]:!prev[label]}));

const exportData = () => {
const json=JSON.stringify(entries,null,2), blob=new Blob([json],{type:“application/json”}), url=URL.createObjectURL(blob), a=document.createElement(“a”);
a.href=url; a.download=`nhatky-dinhduong-${new Date().toISOString().slice(0,10)}.json`; a.click(); URL.revokeObjectURL(url);
};
const importData = e => {
const file=e.target.files[0]; if(!file) return;
const reader=new FileReader();
reader.onload=ev=>{ try{ const data=JSON.parse(ev.target.result); if(Array.isArray(data)) setEntries(data); }catch{ alert(“File không hợp lệ!”); } };
reader.readAsText(file); e.target.value=””;
};

const grouped = entries.reduce((acc,e)=>{const k=toDateKey(e.id);if(!acc[k])acc[k]=[];acc[k].push(e);return acc;},{});
const sortedDays = Object.keys(grouped).sort((a,b)=>b.localeCompare(a));
const pct=(v,g)=>Math.min(100,Math.round(v/g*100));
const calPct=pct(totals.calories,DAILY_GOALS.calories);
const remaining=DAILY_GOALS.calories-totals.calories;
const barColor=p=>p>=100?”#ef4444”:p>=80?”#f97316”:”#22c55e”;
const pFood=selectedFood?FOOD_DB[selectedFood]:null;
const pMult=pFood&&selectedUnit?unitMult(pFood,selectedUnit):1;

